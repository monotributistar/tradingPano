# ── trading-claude environment variables ──────────────────────────────────────
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored — never commit secrets.
# docker-compose files read these automatically.
# Generate BOT_API_SECRET with:  openssl rand -hex 32

# ── API security ──────────────────────────────────────────────────────────────
# Required.  All API endpoints (except /api/health) reject requests
# without this key in the X-API-Key header.
BOT_API_SECRET=                    # openssl rand -hex 32

# ── Exchange credentials ──────────────────────────────────────────────────────
# Supported exchanges: kucoin | okx | gate | kraken | bybit | binance
# Leave blank to use public endpoints only (paper trading + market data).
EXCHANGE_NAME=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSPHRASE=               # Required for KuCoin

# ── CORS — add your VPS domain here ──────────────────────────────────────────
# Comma-separated list of additional allowed origins.
# Example: ALLOWED_ORIGINS=https://trading.mydomain.com,https://my-vps-ip
ALLOWED_ORIGINS=

# ── Ports ─────────────────────────────────────────────────────────────────────
API_PORT=8000                      # FastAPI backend
FRONTEND_PORT=80                   # nginx (prod) or Vite dev server (5173)

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Telegram (Phase 2) ────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather, get your chat ID from @userinfobot
# Leave blank to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── System metrics (Phase 3) ─────────────────────────────────────────────────
# Directory to measure disk usage for the "data dir" metric.
# Defaults to ./data (relative to project root).
# DATA_DIR=/app/data

# ── Bot config path ───────────────────────────────────────────────────────────
# Override only if config.yaml is not at the default location.
# BOT_CONFIG_PATH=/app/crypto_bot/config.yaml

# ── OANDA CFD broker ──────────────────────────────────────────────────────────
# Set exchange: oanda in config.yaml and provide credentials below to trade
# forex and CFDs (EUR/USD, XAU/USD, US30/USD, ...).
# Get a free practice account at https://www.oanda.com/
# Personal access token: https://www.oanda.com/trading/settings/
OANDA_API_KEY=                        # personal access token
OANDA_ACCOUNT_ID=                     # e.g. 001-001-1234567-001
OANDA_ENVIRONMENT=practice            # "practice" (demo) | "live" (real money)

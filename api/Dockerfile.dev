# Development image — hot reload via --reload flag, runs as root for bind mount
# compatibility.  NOT suitable for production.
FROM python:3.11-slim

WORKDIR /app

COPY api/requirements.txt ./api/requirements.txt
RUN pip install --no-cache-dir -r api/requirements.txt

ENV PYTHONPATH=/app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

# Source code is bind-mounted from the host at runtime (see docker-compose.dev.yml).
# --reload watches for file changes and restarts the server automatically.
CMD ["python3", "-m", "uvicorn", "api.main:app", \
     "--host", "0.0.0.0", "--port", "8000", "--reload"]
